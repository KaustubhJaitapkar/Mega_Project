// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  PARTICIPANT
  ORGANISER
  JUDGE
  MENTOR
  SPONSOR
}

enum HackathonStatus {
  DRAFT
  REGISTRATION
  ONGOING
  ENDED
  CANCELLED
}

enum TeamStatus {
  FORMING
  COMPLETE
  DISBANDED
}

enum JoinRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum SubmissionStatus {
  NOT_SUBMITTED
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum CertificateType {
  PARTICIPANT
  WINNER
  RUNNER_UP
  BEST_PROJECT
}

enum CloneStatus {
  NOT_CLONED
  CLONING
  CLONED
  FAILED
}

enum InviteRole {
  JUDGE
  MENTOR
}

// ==================== MODELS ====================

model User {
  id                    String                @id @default(cuid())
  email                 String                @unique

  chatMessagesAsMentor  ChatMessage[]         @relation("ChatMessageToMentor")
  chatMessagesAsUser    ChatMessage[]         @relation("ChatMessageToUser")
  teamMentorAssignments TeamMentor[]

  emailVerified         DateTime?
  name                  String
  image                 String?
  password              String?
  githubUsername        String?
  googleId              String?
  githubId              String?
  role                  UserRole              @default(PARTICIPANT)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  // Relations
  profile               Profile?
  accounts              Account[]
  sessions              Session[]
  hackathonsOrganised   Hackathon[]           @relation("organiser")
  hackathonsJudging     Hackathon[]           @relation("judges")
  hackathonsMentoring   Hackathon[]           @relation("mentors")
  teamMembers           TeamMember[]
  teamCreations         Team[]                @relation("creator")
  joinRequests          JoinRequest[]
  joinRequestsInitiated JoinRequest[]         @relation("joinRequestInitiator")
  scores                Score[]
  helpTickets           HelpTicket[]          @relation("creator")
  helpTicketsAssigned   HelpTicket[]          @relation("assignedTo")
  attendances           Attendance[]
  certificates          Certificate[]
  announcements         Announcement[]
  registrations         HackathonRegistration[]

  @@index([email])
  @@index([role])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Profile {
  id              String    @id @default(cuid())
  userId          String    @unique
  bio             String?
  skills          String[]
  experience      String?   // junior, mid, senior
  company         String?
  website         String?
  resumeUrl       String?
  githubUrl       String?
  linkedin        String?
  linkedinUrl     String?
  twitter         String?
  phone           String?
  country         String?
  timezone        String?
  isPublic        Boolean   @default(true)
  isLookingForTeam Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Hackathon {
  id              String              @id @default(cuid())
  title           String
  tagline         String?
  description     String              @db.Text
  shortDescription String
  bannerUrl       String?
  logoUrl         String?

  staffInvites    StaffInvite[]
  chatMessages    ChatMessage[]
  bannerId        String?
  status          HackathonStatus     @default(DRAFT)
  startDate       DateTime
  endDate         DateTime
  registrationDeadline DateTime
  submissionDeadline DateTime
  maxTeamSize     Int                 @default(5)
  minTeamSize     Int                 @default(1)
  location        String?
  isVirtual       Boolean             @default(true)
  prize           String?
  prizeDetails    Json?               // [{id, title, amount}]
  sponsorIds      String[]
  rules           String?             @db.Text

  // Organiser fields
  contactEmail    String?
  hostName        String?
  theme           String?
  eligibilityDomain String?
  breakfastProvided Boolean           @default(false)
  lunchProvided   Boolean             @default(false)
  dinnerProvided  Boolean             @default(false)
  swagProvided    Boolean             @default(false)
  sponsorDetails  Json?               // [{name, logoUrl, tier, website}]
  judgeDetails    Json?               // [{name, email, company}]
  mentorDetails   Json?               // [{name, email, expertise}]

  // New fields for enhanced hackathon creation
  themedTracks    String[]            @default([]) // ['AI/ML', 'Web3', etc.]
  targetBatches   String[]            @default([]) // ['1st Year', '2nd Year', etc.]
  allowedDepartments String[]         @default([]) // ['Computer Science', etc.]
  allowCrossYearTeams Boolean         @default(false)
  submissionRequirements String[]     @default([]) // ['github', 'demo', 'video', etc.]
  mealSchedule    Json?               // [{id, name, startTime, endTime, day}]
  rubricItems     Json?               // [{id, name, description, maxScore}]
  internalMentors Json?               // [{id, name, email, department, expertise}]

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Relations
  organiserId     String
  organiser       User                @relation("organiser", fields: [organiserId], references: [id], onDelete: Cascade)
  judges          User[]              @relation("judges")
  mentors         User[]              @relation("mentors")
  teams           Team[]
  submissions     Submission[]
  rubrics         Rubric[]
  announcements   Announcement[]
  helpTickets     HelpTicket[]
  attendances     Attendance[]
  certificates    Certificate[]
  timelines       Timeline[]
  registrations   HackathonRegistration[]

  @@index([organiserId])
  @@index([status])
  @@index([startDate])
}

model Timeline {
  id              String    @id @default(cuid())
  hackathonId     String
  title           String
  description     String?
  startTime       DateTime
  endTime         DateTime
  type            String    // keynote, workshop, breaktime, etc
  isActive        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  hackathon Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  @@index([hackathonId])
}

model Team {
  id              String              @id @default(cuid())
  name            String

  teamMentors     TeamMentor[]
  chatMessages    ChatMessage[]
  description     String?
  hackathonId     String
  creatorId       String
  status          TeamStatus          @default(FORMING)
  avatarId        String?
  isOpen          Boolean             @default(true)
  maxMembers      Int                 @default(5)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Relations
  hackathon       Hackathon           @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  creator         User                @relation("creator", fields: [creatorId], references: [id])
  members         TeamMember[]
  submission      Submission?
  joinRequests    JoinRequest[]

  @@unique([hackathonId, name])
  @@index([hackathonId])
  @@index([creatorId])
}

model TeamMember {
  id              String    @id @default(cuid())
  teamId          String
  userId          String
  role            String    @default("member")  // leader, member
  joinedAt        DateTime  @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model JoinRequest {
  id              String              @id @default(cuid())
  teamId          String
  userId          String
  requestedById   String?
  status          JoinRequestStatus   @default(PENDING)
  message         String?
  respondedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestedBy User? @relation("joinRequestInitiator", fields: [requestedById], references: [id], onDelete: SetNull)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([teamId, status])
  @@index([requestedById])
}

model HackathonRegistration {
  id                  String   @id @default(cuid())
  hackathonId         String
  userId              String
  firstName           String
  lastName            String?
  email               String
  phone               String
  gender              String
  location            String
  instituteName       String
  differentlyAbled    Boolean  @default(false)
  userType            String
  domain              String
  course              String
  courseSpecialization String
  graduatingYear      Int
  courseDuration      String
  termsAccepted       Boolean  @default(false)
  selectedTrack       String?  // Participant's chosen themed track
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  hackathon Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([hackathonId, userId])
  @@index([hackathonId])
  @@index([userId])
}

model Submission {
  id              String              @id @default(cuid())
  hackathonId     String
  teamId          String              @unique
  githubUrl       String?
  liveUrl         String?
  status          SubmissionStatus    @default(NOT_SUBMITTED)
  description     String?             @db.Text
  technologies    String[]
  pitchDeckUrl    String?
  isHealthy       Boolean             @default(false)
  healthCheckAt   DateTime?
  submittedAt     DateTime?
  cloneStatus     CloneStatus         @default(NOT_CLONED)
  codeCachePath   String?
  cloneError      String?
  clonedAt        DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  hackathon Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  team      Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  scores    Score[]

  @@index([hackathonId])
  @@index([hackathonId, status])
  @@index([teamId])
  @@index([status])
}

model Rubric {
  id              String    @id @default(cuid())
  hackathonId     String
  name            String
  description     String?   @db.Text
  maxScore        Float     @default(100)
  isActive        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  hackathon Hackathon   @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  items     RubricItem[]

  @@index([hackathonId])
}

model RubricItem {
  id              String    @id @default(cuid())
  rubricId        String
  name            String
  description     String?   @db.Text
  weight          Float     @default(1)
  maxScore        Float     @default(10)
  order           Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  rubric Rubric @relation(fields: [rubricId], references: [id], onDelete: Cascade)
  scores Score[]

  @@index([rubricId])
}

model Score {
  id              String    @id @default(cuid())
  submissionId    String
  rubricItemId    String
  judgerId        String
  score           Float
  comment         String?   @db.Text
  isSealed        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  rubricItem RubricItem @relation(fields: [rubricItemId], references: [id], onDelete: Cascade)
  judge      User       @relation(fields: [judgerId], references: [id], onDelete: Cascade)

  @@unique([submissionId, rubricItemId, judgerId])
  @@index([submissionId])
  @@index([judgerId])
}

model Announcement {
  id              String    @id @default(cuid())
  hackathonId     String
  authorId        String
  title           String
  content         String    @db.Text
  isUrgent        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  hackathon Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([hackathonId])
  @@index([createdAt])
}

model HelpTicket {
  id              String        @id @default(cuid())
  hackathonId     String
  creatorId       String
  assignedToId    String?
  title           String
  description     String        @db.Text
  status          TicketStatus  @default(OPEN)
  priority        String        @default("normal")  // low, normal, high
  category        String        // technical, general, judging
  resolvedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  hackathon Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  creator   User      @relation("creator", fields: [creatorId], references: [id], onDelete: Cascade)
  assignedTo User?     @relation("assignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([hackathonId])
  @@index([creatorId])
  @@index([status])
}

model Attendance {
  id              String    @id @default(cuid())
  hackathonId     String
  userId          String
  checkInTime     DateTime?
  checkOutTime    DateTime?
  breakfastRedeemed Boolean @default(false)
  lunchRedeemed   Boolean   @default(false)
  swagCollected   Boolean   @default(false)
  eventMarks      Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  hackathon Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([hackathonId, userId])
  @@index([hackathonId])
}

model Certificate {
  id              String              @id @default(cuid())
  hackathonId     String
  userId          String
  type            CertificateType
  teamId          String?
  title           String
  description     String?
  certificateUrl  String?
  pdfPath         String?
  issuedAt        DateTime            @default(now())
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  hackathon Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([hackathonId])
  @@index([userId])
}

model StaffInvite {
  id            String     @id @default(cuid())
  hackathonId   String
  email         String
  role          InviteRole
  token         String     @unique
  expiresAt     DateTime
  used          Boolean    @default(false)
  usedAt        DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  hackathon     Hackathon  @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  @@unique([hackathonId, email])
  @@index([token])
  @@index([expiresAt])
}

model TeamMentor {
  id           String   @id @default(cuid())
  teamId       String
  mentorId     String
  assignedAt   DateTime @default(now())

  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  mentor       User     @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  @@unique([teamId, mentorId])
  @@index([teamId])
  @@index([mentorId])
}

model ChatMessage {
  id          String   @id @default(cuid())
  hackathonId String
  teamId      String
  mentorId    String?
  userId      String?
  content     String   @db.Text
  isFromMentor Boolean @default(false)
  createdAt   DateTime @default(now())

  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  mentor      User?    @relation("ChatMessageToMentor", fields: [mentorId], references: [id], onDelete: SetNull)
  user        User?    @relation("ChatMessageToUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([hackathonId, teamId])
  @@index([teamId, createdAt])
  @@index([createdAt])
}
