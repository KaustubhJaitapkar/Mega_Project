# API Key: Key that uniquely identifies your Hackmate instance
HACKMATE_API_KEY=dev-key-12345

# Sentry (optional error tracking)
SENTRY_DSN=

# Stripe (optional for paid features)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# GitHub (optional for GitHub integration)
GITHUB_TOKEN=

# AWS S3 (optional for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# SendGrid (alternative email provider)
SENDGRID_API_KEY=

# Logging
LOG_LEVEL=info
